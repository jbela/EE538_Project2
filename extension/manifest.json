{
  "manifest_version": 3,
  "name": "Lecture Summary Tool",
  "version": "0.1.0",
  "description": "Upload lecture recordings and get summaries, topics, and notes.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["http://localhost:3000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lecture Summary"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
