# Database (e.g. Docker: docker compose up -d from repo root)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lecture_library"

# Must match DEMO_LIBRARY_KEY in extension/popup.js for zero-config local demo (change both if you rotate).
LIBRARY_API_KEY="ee538-local-demo-library-key"

# Used only to sign the browser session cookie (not sent to the extension). Generate e.g. openssl rand -hex 32
LIBRARY_COOKIE_SECRET="change-me-different-random-string"
